# ============================================
# StreamZ - Environment Configuration
# ============================================

# ---- Database (Neon PostgreSQL) ----
DATABASE_URL=postgresql://streamz:streamz@localhost:5432/streamz?schema=public
DATABASE_POOL_URL=postgresql://streamz:streamz@localhost:5432/streamz?schema=public&connection_limit=10

# ---- Redis (BullMQ) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Object Storage (Cloudflare R2 / S3) ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=streamz
S3_REGION=auto
S3_PUBLIC_URL=http://localhost:9000/streamz

# ---- AI (OpenRouter) ----
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# ---- Twitch ----
TWITCH_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
TWITCH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
TWITCH_EVENTSUB_SECRET=xxxxxxxxxxxxxxxxxxxx
TWITCH_WEBHOOK_URL=https://your-domain.com/api/webhooks/twitch

# ---- YouTube ----
YOUTUBE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
YOUTUBE_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx
YOUTUBE_WEBHOOK_URL=https://your-domain.com/api/webhooks/youtube

# ---- Instagram (Meta Graph API) ----
INSTAGRAM_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxx
INSTAGRAM_BUSINESS_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx

# ---- TikTok ----
TIKTOK_CLIENT_KEY=xxxxxxxxxxxxxxxxxxxx
TIKTOK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx

# ---- App ----
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxx
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development

# ---- Fly.io ----
FLY_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
FLY_APP_NAME=streamz
